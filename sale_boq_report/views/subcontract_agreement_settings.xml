<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_sale_order_form_subcontract_agreement_scope" model="ir.ui.view">
        <field name="name">sale.order.form.subcontract.agreement.scope</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='sale_order_template_id']" position="after">
                <field name="subcontract_scope_with_lines" widget="boolean_toggle"/>
            </xpath>
        </field>
    </record>

</odoo>
